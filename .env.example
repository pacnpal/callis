# =============================================================================
# Callis Configuration
# =============================================================================
# OPTIONAL — copy to .env to override defaults:
#   cp .env.example .env
#   docker compose up -d
#
# Individual values below are optional unless your chosen auth/deployment mode requires them.

# Secret key for JWT signing and TOTP encryption.
# If not set, one is auto-generated on first start and persisted to /data/.secret_key.
# To set manually: openssl rand -hex 32
# SECRET_KEY=

# Database URL. Default is SQLite at /data/callis.db.
# For PostgreSQL: postgresql+asyncpg://user:pass@host:5432/callis
# DATABASE_URL=sqlite+aiosqlite:////data/callis.db

# External SSH port (default: 2222)
# SSH_PORT=2222

# External web UI port (default: 8080)
# WEB_PORT=8080

# Public base URL — used in SSH config snippets shown in the UI
# BASE_URL=http://localhost:8080

# Session idle timeout in seconds (default: 1800 = 30 minutes)
# SESSION_IDLE_TIMEOUT=1800

# Session absolute max lifetime in seconds (default: 28800 = 8 hours)
# SESSION_MAX_LIFETIME=28800

# Maximum SSH keys per user (default: 5)
# MAX_KEYS_PER_USER=5

# Authentication mode: "local" only (OIDC not yet implemented)
# AUTH_MODE=local

# Set to true to enable HSTS and Secure cookie flag
# HTTPS_ENABLED=false

# Development mode — enables verbose SQL logging
# Cookie Secure flag is controlled by HTTPS_ENABLED, not DEV_MODE
# DEV_MODE=false

# Log level: debug, info, warning, error (default: info)
# LOG_LEVEL=info

# Timezone for log timestamps (default: UTC)
# TZ=UTC

# ---------------------------------------------------------------------------
# OIDC (only if AUTH_MODE=oidc)
# ---------------------------------------------------------------------------

# OIDC_ISSUER=https://auth.example.com
# OIDC_CLIENT_ID=callis
# OIDC_CLIENT_SECRET=

